+    // Claude-Code-like session permission mode. This is SESSION-LEVEL state and
+    // does NOT change the active agent/persona. The TUI keeps the current value
+    // for display + immediate feedback and pushes it to the server (which reads
+    // it in the PermissionV2 resolver) over a small raw request to avoid an SDK
+    // regeneration.
+    function createPermissionMode() {
+      const [modeStore, setModeStore] = createStore({
+        current: "normal" as PermissionModeValue,
+      })
+      async function push(sessionID: string | undefined, mode: PermissionModeValue) {
+        if (!sessionID) return
+        try {
+          const url = new URL(`/permission/mode/${sessionID}`, sdk.url)
+          if (sdk.directory) url.searchParams.set("directory", sdk.directory)
+          await (sdk.fetch ?? fetch)(url.toString(), {
+            method: "PUT",
+            headers: {
+              "Content-Type": "application/json",
+              ...(sdk.directory ? { "x-opencode-directory": encodeURIComponent(sdk.directory) } : {}),
+            },
+            body: JSON.stringify({ mode }),
+          })
+        } catch {
+          // best-effort; the local display still reflects the requested mode
+        }
+      }
+      return {
+        list() {
+          return PERMISSION_MODES
+        },
+        current() {
+          return modeStore.current
+        },
+        label() {
+          return modeStore.current.toUpperCase()
+        },
+        set(mode: PermissionModeValue, sessionID?: string) {
+          setModeStore("current", mode)
+          void push(sessionID, mode)
+          return mode
+        },
+        cycle(sessionID?: string) {
+          const order = PERMISSION_MODES
+          const index = order.indexOf(modeStore.current)
+          const next = order[(index + 1) % order.length]
+          setModeStore("current", next)
+          void push(sessionID, next)
+          return next
+        },
+        // Re-push the current mode for a session (used when sending a prompt so
+        // the server has the mode even after a restart).
+        sync(sessionID?: string) {
+          void push(sessionID, modeStore.current)
+        },
+      }
+    }
+
+    const permissionMode = createPermissionMode()
