+
+    function set(mode: PermissionMode) {
+      setStore("mode", mode)
+    }
+
+    function cycle() {
+      setStore("mode", (mode) => {
+        const idx = PermissionModeOrder.indexOf(mode)
+        return PermissionModeOrder[(idx + 1) % PermissionModeOrder.length] ?? "normal"
+      })
+    }
+
+    function decision(request: PermissionRequest): PermissionDecision {
+      if (store.mode === "normal") return "prompt"
+
+      if (store.mode === "plan") {
+        if (isPlanReject(request)) return "reject"
+        return "prompt"
+      }
+
+      if (store.mode === "auto") {
+        if (hasDangerousCommandShape(request)) return "reject"
+        if (isSafeAutoApprove(request)) return "approve"
+        return "prompt"
+      }
+
+      return "prompt"
+    }
+
     return {
       get mode() {
         return store.mode
       },
-      set(mode: PermissionMode) {
-        setStore("mode", mode)
-      },
+      set,
+      cycle,
       toggle() {
-        setStore("mode", (mode) => (mode === "auto" ? "normal" : "auto"))
+        cycle()
       },
+      decision,
     }
   },
 })
