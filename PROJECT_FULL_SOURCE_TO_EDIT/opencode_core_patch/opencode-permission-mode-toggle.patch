 import { createStore } from "solid-js/store"
+import type { PermissionRequest } from "@opencode-ai/sdk/v2"
 import { useArgs } from "./args"
 import { createSimpleContext } from "./helper"
 
-export type PermissionMode = "auto" | "normal"
+export type PermissionMode = "plan" | "normal" | "auto"
+export type PermissionDecision = "prompt" | "approve" | "reject"
+
+const PermissionModeOrder: PermissionMode[] = ["normal", "auto", "plan"]
+
+const PlanRejectPermissions = new Set([
+  "edit",
+  "bash",
+  "task",
+  "webfetch",
+  "websearch",
+  "external_directory",
+  "doom_loop",
+  "question",
+  "plan_exit",
+])
+
+function isPlanRejected(request: PermissionRequest) {
+  if (PlanRejectPermissions.has(request.permission)) return true
+  return false
+}
 
 export const { use: usePermission, provider: PermissionProvider } = createSimpleContext({
   name: "Permission",
   init: () => {
     const args = useArgs()
     const [store, setStore] = createStore<{ mode: PermissionMode }>({
       mode: args.auto ? "auto" : "normal",
     })
+
+    function set(mode: PermissionMode) {
+      setStore("mode", mode)
+    }
+
+    function cycle() {
+      setStore("mode", (mode) => {
+        const idx = PermissionModeOrder.indexOf(mode)
+        return PermissionModeOrder[(idx + 1) % PermissionModeOrder.length] ?? "normal"
+      })
+    }
+
+    function decision(request: PermissionRequest): PermissionDecision {
+      if (store.mode === "normal") return "prompt"
+
+      if (store.mode === "plan") {
+        if (isPlanRejected(request)) return "reject"
+        return "prompt"
+      }
+
+      if (store.mode === "auto") return "approve"
+
+      return "prompt"
+    }
+
     return {
       get mode() {
         return store.mode
       },
-      set(mode: PermissionMode) {
-        setStore("mode", mode)
-      },
+      set,
+      cycle,
       toggle() {
-        setStore("mode", (mode) => (mode === "auto" ? "normal" : "auto"))
+        cycle()
       },
+      decision,
     }
   },
 })
