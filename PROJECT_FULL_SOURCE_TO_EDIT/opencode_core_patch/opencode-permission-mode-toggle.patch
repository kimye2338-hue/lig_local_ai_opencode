 import { createStore } from "solid-js/store"
 import { useArgs } from "./args"
 import { createSimpleContext } from "./helper"
 
-export type PermissionMode = "auto" | "normal"
+// Permission approval policy. This is independent of the active agent/persona,
+// the current workflow, and the current model - it only decides how incoming
+// "permission.asked" events are handled by the TUI.
+//   ASK  = show permission requests to the user (default OpenCode behavior).
+//   AUTO = auto-approve (reply "once") the requests that reach the TUI.
+// Explicit "deny" decisions are resolved in opencode core before a request is
+// ever surfaced as "permission.asked", so AUTO can never bypass an explicit deny.
+export type PermissionMode = "ask" | "auto"
+
+const PermissionModeOrder: PermissionMode[] = ["ask", "auto"]
 
 export const { use: usePermission, provider: PermissionProvider } = createSimpleContext({
   name: "Permission",
   init: () => {
     const args = useArgs()
     const [store, setStore] = createStore<{ mode: PermissionMode }>({
-      mode: args.auto ? "auto" : "normal",
+      mode: args.auto ? "auto" : "ask",
     })
+
+    function set(mode: PermissionMode) {
+      setStore("mode", mode)
+    }
+
+    function cycle() {
+      setStore("mode", (mode) => {
+        const idx = PermissionModeOrder.indexOf(mode)
+        return PermissionModeOrder[(idx + 1) % PermissionModeOrder.length] ?? "ask"
+      })
+    }
+
     return {
       get mode() {
         return store.mode
       },
-      set(mode: PermissionMode) {
-        setStore("mode", mode)
-      },
+      set,
+      cycle,
       toggle() {
-        setStore("mode", (mode) => (mode === "auto" ? "normal" : "auto"))
+        cycle()
       },
     }
   },
 })
