 import { createStore } from "solid-js/store"
+import type { PermissionRequest } from "@opencode-ai/sdk/v2"
 import { useArgs } from "./args"
 import { createSimpleContext } from "./helper"
 
-export type PermissionMode = "auto" | "normal"
+export type PermissionMode = "plan" | "normal" | "auto"
+export type PermissionDecision = "prompt" | "approve" | "reject"
+
+const PermissionModeOrder: PermissionMode[] = ["normal", "auto", "plan"]
+
+const ReadLikePermissions = new Set(["read", "glob", "grep", "list", "todowrite"])
+const PlanRejectPermissions = new Set([
+  "edit",
+  "bash",
+  "task",
+  "webfetch",
+  "websearch",
+  "external_directory",
+  "doom_loop",
+  "question",
+  "plan_exit",
+])
+
+const AutoPromptPermissions = new Set([
+  "external_directory",
+  "webfetch",
+  "websearch",
+  "task",
+  "doom_loop",
+  "question",
+  "plan_enter",
+  "plan_exit",
+])
+
+const DangerousCommandPatterns = [
+  /\bcat\s*>\s*/i,
+  /<<\s*['"]?\w+['"]?/i,
+  /\bpython(?:\d+(?:\.\d+)?)?\s+-c\b/i,
+  /\bpy\s+-3(?:\.\d+)?\s+-c\b/i,
+  /\bpowershell\b.*\bencodedcommand\b/i,
+  /\brm\s+-rf\b/i,
+  /\bdel\s+\/s\b/i,
+  /\brmdir\s+\/s\b/i,
+  /\bformat\s+[a-z]:/i,
+  /\bcurl\b.*\|\s*bash\b/i,
+  /\biwr\b.*\|\s*iex\b/i,
+  /<tool_call>/i,
+  /\bfunctions\.bash\s*\(/i,
+  /\bOTP\b|\bcookie\b|\btoken\b|\bpassword\b|\bcredential\b/i,
+]
+
+const SafeCommandPatterns = [
+  /^\s*(git\s+(status|diff|log|show|rev-parse|branch)(\s+[-\w./:=]+)*)\s*$/i,
+  /^\s*(dir|ls)(\s+[-\w./:=]+)?\s*$/i,
+  /^\s*(type|cat)\s+[-\w./:=]+\s*$/i,
+  /^\s*(findstr|grep)\s+[-\w\s"'./:=]+\s*$/i,
+  /^\s*(py\s+-3\.11|python)\s+-m\s+py_compile\s+[-\w./:=]+\s*$/i,
+  /^\s*(bun|npm|pnpm|yarn)\s+(test|run\s+(test|typecheck|check|build))\s*$/i,
+]
+
+function requestText(request: PermissionRequest) {
+  const pieces: string[] = []
+  pieces.push(request.permission)
+  for (const pattern of request.patterns ?? []) pieces.push(pattern)
+  const meta = request.metadata
+  if (meta && typeof meta === "object") {
+    for (const value of Object.values(meta)) {
+      if (typeof value === "string") pieces.push(value)
+    }
+  }
+  return pieces.join("\n")
+}
+
+function hasDangerousCommandShape(request: PermissionRequest) {
+  const text = requestText(request)
+  return DangerousCommandPatterns.some((pattern) => pattern.test(text))
+}
+
+function isSafeBashRequest(request: PermissionRequest) {
+  const text = requestText(request)
+  return SafeCommandPatterns.some((pattern) => pattern.test(text))
+}
+
+function hasFilePath(request: PermissionRequest) {
+  const filepath = request.metadata?.filepath
+  return typeof filepath === "string" && filepath.trim() !== ""
+}
+
+function isSafeAutoApprove(request: PermissionRequest) {
+  if (hasDangerousCommandShape(request)) return false
+  if (AutoPromptPermissions.has(request.permission)) return false
+  if (ReadLikePermissions.has(request.permission)) return true
+  if (request.permission === "edit") return hasFilePath(request)
+  if (request.permission === "bash") return isSafeBashRequest(request)
+  return false
+}
+
+function isPlanReject(request: PermissionRequest) {
+  if (hasDangerousCommandShape(request)) return true
+  if (PlanRejectPermissions.has(request.permission)) return true
+  return false
+}
 
 export const { use: usePermission, provider: PermissionProvider } = createSimpleContext({
