@echo off
chcp 65001 >nul
setlocal EnableExtensions
set "PYTHONUTF8=1"
set "PYTHONIOENCODING=utf-8"
set "LIG_HOTFIX_PACKAGE_DIR=%~dp0"
set "BAT_SELF=%~f0"
set "HOTFIX_PY=%TEMP%\opencodelig_hotfix_%RANDOM%%RANDOM%.py"

powershell -NoProfile -ExecutionPolicy Bypass -Command "$self=$env:BAT_SELF; $out=$env:HOTFIX_PY; $lines=[System.IO.File]::ReadAllLines($self); $marker='__OPENCODELIG_HOTFIX_PAYLOAD_BASE64__'; $idx=[Array]::IndexOf($lines,$marker); if($idx -lt 0){Write-Host '[ERROR] embedded payload marker not found'; exit 20}; $b64=($lines[($idx+1)..($lines.Length-1)] -join ''); [System.IO.File]::WriteAllBytes($out,[Convert]::FromBase64String($b64))"
if errorlevel 1 (
  echo [ERROR] Failed to extract embedded hotfix payload.
  pause
  exit /b 1
)

where py >nul 2>nul
if %ERRORLEVEL%==0 (
  py -3.11 "%HOTFIX_PY%" %*
) else (
  python "%HOTFIX_PY%" %*
)
set "RC=%ERRORLEVEL%"
if exist "%HOTFIX_PY%" del /q "%HOTFIX_PY%" >nul 2>&1
if not "%RC%"=="0" (
  echo.
  echo [ERROR] Patch failed. Review:
  echo   %USERPROFILE%\OpenCodeLIG_USERDATA\diagnostics\patches
  pause
  exit /b %RC%
)

echo.
echo [OK] Patch finished.
echo Latest check report:
echo   %USERPROFILE%\OpenCodeLIG_USERDATA\diagnostics\pending_checks\pending-check-last.md
echo Patch log:
echo   %USERPROFILE%\OpenCodeLIG_USERDATA\diagnostics\patches
echo.
pause
exit /b 0
