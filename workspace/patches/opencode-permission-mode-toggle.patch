diff --git a/packages/tui/src/context/permission.tsx b/packages/tui/src/context/permission.tsx
index 13a6ba8..c5afb24 100644
--- a/packages/tui/src/context/permission.tsx
+++ b/packages/tui/src/context/permission.tsx
@@ -2,24 +2,40 @@ import { createStore } from "solid-js/store"
 import { useArgs } from "./args"
 import { createSimpleContext } from "./helper"
 
-export type PermissionMode = "auto" | "normal"
+// Permission approval policy. This is independent of the active agent/persona,
+// current workflow, and model. It only decides how permission prompts surfaced
+// to the TUI are handled.
+export type PermissionMode = "ask" | "auto" | "full"
+
+const PermissionModeOrder: PermissionMode[] = ["ask", "auto", "full"]
 
 export const { use: usePermission, provider: PermissionProvider } = createSimpleContext({
   name: "Permission",
   init: () => {
     const args = useArgs()
     const [store, setStore] = createStore<{ mode: PermissionMode }>({
-      mode: args.auto ? "auto" : "normal",
+      mode: args.auto ? "auto" : "ask",
     })
+
+    function set(mode: PermissionMode) {
+      setStore("mode", mode)
+    }
+
+    function cycle() {
+      setStore("mode", (mode) => {
+        const idx = PermissionModeOrder.indexOf(mode)
+        return PermissionModeOrder[(idx + 1) % PermissionModeOrder.length] ?? "ask"
+      })
+    }
+
     return {
       get mode() {
         return store.mode
       },
-      set(mode: PermissionMode) {
-        setStore("mode", mode)
-      },
+      set,
+      cycle,
       toggle() {
-        setStore("mode", (mode) => (mode === "auto" ? "normal" : "auto"))
+        cycle()
       },
     }
   },
