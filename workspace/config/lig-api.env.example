# LIG API provider configuration.
# 설치 시 이 파일이 %USERPROFILE%\OpenCodeLIG_USERDATA\secrets\lig-api.env 로 복사되어
# 별도 설정 없이 바로 모델이 잡힌다. (사내 개발 게이트웨이 값 반영, 2026-07-07)
# 주의: API 키가 이 파일에 들어 있으므로 패키지를 외부로 공유하지 말 것.

# Profile:
#   company_gateway: internal OpenAI-compatible gateway, requires base URL + API key.
#   local_openai: local OpenAI-compatible server, no API key required.
LIG_PROVIDER_PROFILE=company_gateway

# 사내 게이트웨이 (호스트 + /ai_infra/llm_api 접두. 뒤의 /gateway/... 라우트가 이어붙는다)
LIG_GATEWAY_BASE_URL=http://ais.ligdefenseaerospace.com/ai_infra/llm_api
LIG_API_KEY=ai_infra_llm_api_2024_06
LIG_DEFAULT_PROVIDER=lig-coding
LIG_API_TIMEOUT_SEC=120

# Company route overrides. Edit when gateway route paths change.
# NOTE: the "/gateway/" prefix is required (measured 2026-07-03) — without it
# the port-80 web server answers 404 instead of the LLM backend.
LIG_ROUTE_CODING=/gateway/EXAONE-4.5-33B-vibe_coding_think_off/v1
LIG_ROUTE_CHAT=/gateway/EXAONE-4.5-33B-default_think_off/v1
LIG_ROUTE_FALLBACK=/gateway/Qwen3.6-27B-vibe_coding_think_off/v1

# Company model overrides. Edit when gateway model names change.
LIG_MODEL_CODING=EXAONE-4.5-33B
LIG_MODEL_CHAT=EXAONE-4.5-33B
LIG_MODEL_FALLBACK=Qwen3.6-27B

# Local development profile. Used when LIG_PROVIDER_PROFILE=local_openai.
LIG_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
LIG_LOCAL_MODEL=qwen2.5:7b-instruct
